<?xml version="1.0" encoding="utf-8"?>
<!--
  Sparse package manifest ("packaging with external location").

  This grants the normal PhoneNotificationsVR.exe *package identity* WITHOUT converting it to a full MSIX
  app. Package identity is what unlocks the Windows UserNotificationListener API (RequestAccessAsync).

  The real .exe stays wherever you built it; `-ExternalLocation` (see Register-Identity.ps1) points Windows
  at that folder. The <Identity Publisher> below MUST match the code-signing certificate's subject.
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap10="http://schemas.microsoft.com/appx/manifest/uap/windows10/10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap uap10 rescap">

  <Identity Name="PhoneNotificationsVR"
            Publisher="CN=PhoneNotificationsVR Dev"
            Version="1.0.0.0"
            ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>Phone Notifications for SteamVR</DisplayName>
    <PublisherDisplayName>PhoneNotificationsVR</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
    <uap10:AllowExternalContent>true</uap10:AllowExternalContent>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.19041.0" MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <Application Id="App"
                 Executable="PhoneNotificationsVR.exe"
                 uap10:RuntimeBehavior="win32App"
                 uap10:TrustLevel="mediumIL">
      <uap:VisualElements
        DisplayName="Phone Notifications for SteamVR"
        Description="Shows iPhone notifications inside SteamVR"
        BackgroundColor="#16181E"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png" />
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
