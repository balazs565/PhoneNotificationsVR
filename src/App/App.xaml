<Application x:Class="PhoneNotificationsVR.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PhoneNotificationsVR.App.Converters">
    <Application.Resources>
        <ResourceDictionary>

            <conv:BoolToBrushConverter x:Key="StatusBrush"
                                       TrueBrush="#34C759" FalseBrush="#FF5A5A" />
            <conv:BoolToTextConverter x:Key="ConnText"
                                      TrueText="Connected" FalseText="Not connected" />

            <!-- Simple dark theme palette -->
            <SolidColorBrush x:Key="Bg" Color="#16181E" />
            <SolidColorBrush x:Key="Panel" Color="#1E2129" />
            <SolidColorBrush x:Key="Panel2" Color="#252A34" />
            <SolidColorBrush x:Key="Fg" Color="#EEF1F6" />
            <SolidColorBrush x:Key="Dim" Color="#96A0B0" />
            <SolidColorBrush x:Key="Accent" Color="#5E84F1" />

            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource Fg}" />
                <Setter Property="FontFamily" Value="Segoe UI" />
            </Style>
            <Style x:Key="H1" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource Fg}" />
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,0,0,10" />
            </Style>
            <Style x:Key="Card" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource Panel}" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="Margin" Value="0,0,0,12" />
            </Style>
            <Style TargetType="Button">
                <Setter Property="Background" Value="{StaticResource Accent}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="14,8" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
